<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Code Glow Learner</title>
    <style>
        :root {
            --blue-glow: 0 0 20px 5px rgba(0, 150, 255, 0.7);
            --red-glow: 0 0 30px 10px rgba(255, 0, 0, 0.9);
            --green-glow: 0 0 30px 10px rgba(0, 255, 0, 0.9);
        }

        body {
            background-color: #0a0a0a;
            color: white;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
            margin: 0;
            padding: 20px;
        }

        /* Menu Styles */
        .menu-bar {
            margin-bottom: 30px;
            display: flex;
            gap: 20px;
        }

        button {
            padding: 10px 20px;
            cursor: pointer;
            background: #222;
            color: white;
            border: 1px solid #444;
            border-radius: 5px;
            transition: 0.3s;
        }

        button:hover { background: #333; border-color: #0096ff; }
        button.active { background: #0096ff; border-color: white; }

        /* Level Grid */
        .level-grid {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 15px;
            margin-bottom: 30px;
        }

        .level-card {
            width: 80px;
            height: 80px;
            background: #1a1a1a;
            border: 1px solid #333;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 10px;
            cursor: pointer;
            position: relative;
        }

        /* Hover Tooltip */
        .level-card:hover::after {
            content: attr(data-tooltip);
            position: absolute;
            bottom: 110%;
            left: 50%;
            transform: translateX(-50%);
            background: #333;
            padding: 10px;
            border-radius: 5px;
            width: 150px;
            font-size: 12px;
            text-align: center;
            z-index: 10;
            border: 1px solid #0096ff;
        }

        /* Typing Area */
        #glow-container {
            padding: 15px;
            border-radius: 15px;
            box-shadow: var(--blue-glow);
            transition: box-shadow 0.2s ease;
            margin-top: 20px;
        }

        #typing-area {
            width: 600px;
            height: 150px;
            background-color: black;
            color: white;
            border: none;
            border-radius: 8px;
            padding: 20px;
            font-family: 'Courier New', monospace;
            font-size: 20px;
            outline: none;
            resize: none;
        }

        .target-box {
            background: #222;
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 10px;
            font-family: monospace;
            color: #00ff00;
        }

        .status-text { margin-top: 10px; font-weight: bold; }

        /* Custom AI Area */
        .custom-section {
            margin-top: 40px;
            border-top: 1px solid #333;
            padding-top: 20px;
            width: 100%;
            max-width: 600px;
            text-align: center;
        }

        .hidden { display: none; }
    </style>
</head>
<body>

    <h1>Code Master Academy</h1>

    <div class="menu-bar">
        <button id="html-btn" class="active" onclick="switchLang('HTML')">HTML Mode</button>
        <button id="py-btn" onclick="switchLang('Python')">Python Mode</button>
    </div>

    <div class="level-grid" id="level-grid">
        </div>

    <div id="game-area">
        <div id="level-info">
            <h3 id="current-task-title">Select a level to start</h3>
            <div class="target-box" id="target-display">Your target code will appear here...</div>
        </div>

        <div id="glow-container">
            <textarea id="typing-area" placeholder="Type here..." disabled></textarea>
        </div>
        <div class="status-text" id="status">Progress: Level 0 (Sub 0/3)</div>
    </div>

    <div class="custom-section">
        <h3>Custom AI Level</h3>
        <input type="text" id="ai-input" placeholder="e.g. 'Make a level about links'" style="padding:10px; width:70%;">
        <button onclick="generateAILevel()">Generate</button>
    </div>

    <script>
        let currentLang = 'HTML';
        let currentLevel = 1;
        let currentSub = 1;
        let targetCode = "";

        const levels = {
            HTML: [
                { title: "Headers", desc: "Learn structure with H1-H3 tags.", sub: ["<h1>Title</h1>", "<h2>Subtitle</h2>", "<h3>Small Header</h3>"] },
                { title: "Paragraphs", desc: "Using the P tag for text.", sub: ["<p>Hello</p>", "<p>World</p>", "<p>Code</p>"] },
                { title: "Links", desc: "Creating anchor tags.", sub: ["<a href='#'>Link</a>", "<a>Click me</a>", "<a target='_blank'>"] },
                { title: "Images", desc: "Adding images to sites.", sub: ["<img src=''>", "<img alt='dog'>", "<img width='100'>"] },
                // ... placeholders for 5-10
            ],
            Python: [
                { title: "Printing", desc: "Learn to output text.", sub: ["print('Hi')", "print(123)", "print('Done')"] },
                { title: "Variables", desc: "Storing data in names.", sub: ["x = 5", "name = 'Bruce'", "is_coding = True"] },
                { title: "Lists", desc: "Groups of items.", sub: ["my_list = []", "items = [1, 2]", "list.append(1)"] },
                { title: "Loops", desc: "Repeat code logic.", sub: ["for i in range(5):", "while True:", "while x < 10:"] }
            ]
        };

        // Fill in placeholders to reach 10 levels
        ['HTML', 'Python'].forEach(lang => {
            while(levels[lang].length < 10) {
                levels[lang].push({ title: "Level " + (levels[lang].length + 1), desc: "Advanced coding challenge.", sub: ["# Coming soon", "# Practice more", "# Master code"] });
            }
        });

        function initGrid() {
            const grid = document.getElementById('level-grid');
            grid.innerHTML = '';
            levels[currentLang].forEach((lvl, index) => {
                const card = document.createElement('div');
                card.className = 'level-card';
                card.innerText = index + 1;
                card.setAttribute('data-tooltip', lvl.title + ": " + lvl.desc);
                card.onclick = () => startLevel(index + 1);
                grid.appendChild(card);
            });
        }

        function switchLang(lang) {
            currentLang = lang;
            document.getElementById('html-btn').classList.toggle('active', lang === 'HTML');
            document.getElementById('py-btn').classList.toggle('active', lang === 'Python');
            initGrid();
        }

        function startLevel(lvlNum) {
            currentLevel = lvlNum;
            currentSub = 1;
            loadSubLevel();
        }

        function loadSubLevel() {
            const data = levels[currentLang][currentLevel - 1];
            targetCode = data.sub[currentSub - 1];
            document.getElementById('current-task-title').innerText = `${data.title} (Part ${currentSub}/3)`;
            document.getElementById('target-display').innerText = targetCode;
            document.getElementById('typing-area').value = "";
            document.getElementById('typing-area').disabled = false;
            document.getElementById('typing-area').focus();
            updateStatus();
        }

        function updateStatus() {
            document.getElementById('status').innerText = `Progress: ${currentLang} Level ${currentLevel} (Sub ${currentSub}/3)`;
        }

        const input = document.getElementById('typing-area');
        const container = document.getElementById('glow-container');

        input.addEventListener('input', () => {
            const val = input.value;

            if (val === targetCode) {
                container.style.boxShadow = "var(--green-glow)";
                setTimeout(() => {
                    if (currentSub < 3) {
                        currentSub++;
                        loadSubLevel();
                        container.style.boxShadow = "var(--blue-glow)";
                    } else {
                        alert("Level Complete! Choose a new one from the grid.");
                        input.disabled = true;
                    }
                }, 500);
            } else if (targetCode.startsWith(val)) {
                container.style.boxShadow = "var(--blue-glow)";
            } else {
                container.style.boxShadow = "var(--red-glow)";
            }
        });

        function generateAILevel() {
            const prompt = document.getElementById('ai-input').value;
            if (!prompt) return;
            alert("AI Generating: " + prompt);
            // Simulated AI Result
            targetCode = "print('Custom AI Level Ready!')";
            document.getElementById('target-display').innerText = targetCode;
            document.getElementById('current-task-title').innerText = "AI Custom Level";
            input.value = "";
            input.disabled = false;
        }

        initGrid();
    </script>
</body>
</html>
